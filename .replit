modules = ["nodejs-20", "python-3.12", "web", "nix"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
CLIENT_ORIGIN = "https://8d90973b-07ef-4aee-8062-0672a562b7e2-00-2y5jvtluzn084.pike.replit.dev"
JWT_SECRET = "face-app-jwt-secret-key-2024"
PORT = "8080"
API_BASE_URL = "http://localhost:8080"
INFERENCE_BASE_URL = "http://localhost:7860"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd client && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd api && npm start"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd api && npm start & cd client && npm run build && npx serve -s dist -l 5000"]
